generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum InquiryStatus {
  OPEN
  AI_DRAFTED
  REVIEW_NEEDED
  COMPLETED
}

enum InquiryCategory {
  GENERAL
  TROUBLESHOOTING
  BILLING
  FEATURE_REQUEST
  OTHER
}

enum InquiryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum AiEvaluationResult {
  ACCEPTED
  EDITED
  REJECTED
}

enum InquiryAuditAction {
  CREATED
  AI_ANALYZED
  STATUS_UPDATED
  ASSIGNEE_UPDATED
  AI_RESULT_SAVED
  COMMENT_ADDED
  FIELD_UPDATED
}

model Inquiry {
  id           String           @id @default(cuid())
  title        String
  customerName String
  inquiryBody  String
  assigneeName String?
  slaDueAt     DateTime?

  category     InquiryCategory?
  priority     InquiryPriority?
  summary      String?
  draftReply   String?
  aiReason     String?

  status       InquiryStatus    @default(OPEN)
  approvalStatus ApprovalStatus @default(NOT_REQUESTED)
  approvalRequestedAt DateTime?
  approvedAt   DateTime?
  approvedBy   String?
  approvalComment String?

  comments     InquiryComment[]
  auditLogs    InquiryAuditLog[]
  tags         InquiryTag[]
  aiEvaluations AiEvaluationLog[]
  attachments  InquiryAttachment[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model InquiryTag {
  id         String   @id @default(cuid())
  inquiryId  String
  name       String
  createdAt  DateTime @default(now())

  inquiry    Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}

model InquiryComment {
  id         String   @id @default(cuid())
  inquiryId  String
  authorName String   @default("担当者")
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inquiry    Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}

model InquiryAuditLog {
  id          String             @id @default(cuid())
  inquiryId   String
  action      InquiryAuditAction
  actorName   String             @default("システム")
  fieldName   String?
  beforeValue String?
  afterValue  String?
  comment     String?
  createdAt   DateTime           @default(now())

  inquiry     Inquiry            @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}

model KnowledgeArticle {
  id           String           @id @default(cuid())
  title        String
  summary      String
  content      String
  category     InquiryCategory?
  priority     InquiryPriority?
  tagsText     String?
  keywordsText String?
  createdBy    String           @default("担当者")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category, priority, updatedAt])
}

model ReplyTemplate {
  id         String           @id @default(cuid())
  title      String
  description String
  body       String
  category   InquiryCategory?
  priority   InquiryPriority?
  createdBy  String           @default("担当者")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([category, priority, updatedAt])
}

model AiEvaluationLog {
  id          String             @id @default(cuid())
  inquiryId   String
  result      AiEvaluationResult
  memo        String?
  evaluatedBy String             @default("担当者")
  createdAt   DateTime           @default(now())

  inquiry     Inquiry            @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}

model InquiryAttachment {
  id         String   @id @default(cuid())
  inquiryId  String
  fileName   String
  mimeType   String?
  fileSize   Int
  url        String
  uploadedBy String   @default("担当者")
  createdAt  DateTime @default(now())

  inquiry    Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
}
